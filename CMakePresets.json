{
  "version": 4,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "x64-debug",
      "displayName": "x64 Debug (VS 2022)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/x64-debug",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x64-release",
      "inherits": "x64-debug",
      "displayName": "x64 Release (VS 2022)",
      "binaryDir": "${sourceDir}/build/x64-release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    }
  ],
  "buildPresets": [
    { "name": "x64-debug", "configurePreset": "x64-debug", "configuration": "Debug" },
    { "name": "x64-release", "configurePreset": "x64-release", "configuration": "Release" }
  ]
}
